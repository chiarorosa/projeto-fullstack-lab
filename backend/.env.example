# Base defaults for local development.
# Copy this file to .env and adjust values for your machine.
APP_ENV=development
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXECUTE_REQUESTS=10
RATE_LIMIT_PROVIDER_TEST_REQUESTS=30
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Provider API keys used by Test Provider fallback (optional in development)
# Precedence for Test Provider: apiKey input > credentialRef > provider env var
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional in development. Required in non-development environments.
# WARNING: Replace the default keys in your environment.
API_BEARER_TOKEN=Qm7j9wKxVf3R2sL8pNcT6yHk4dZa1uEeG5rJm0XqBw9CvFsN7tPyLuI2
CREDENTIAL_ENCRYPTION_KEY=6e2f9c4ab8d1735f0a6e4c91d2fb7a385c0f1e97ab34d6287e51c9d40bf6a2e3
