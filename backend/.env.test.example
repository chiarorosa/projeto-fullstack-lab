# Test environment defaults
APP_ENV=test
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXECUTE_REQUESTS=10
RATE_LIMIT_PROVIDER_TEST_REQUESTS=30
CORS_ALLOW_ORIGINS=http://localhost:5173

# Required when credentials encryption/decryption is exercised in tests
CREDENTIAL_ENCRYPTION_KEY=replace-with-test-key

# Optional when AUTH_ENABLED=false
API_BEARER_TOKEN=

# Optional provider keys for Test Provider fallback in test env
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
