# Staging baseline (non-development environment)
APP_ENV=staging
AUTH_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXECUTE_REQUESTS=10
RATE_LIMIT_PROVIDER_TEST_REQUESTS=30

# Replace with real secrets before deploying
API_BEARER_TOKEN=replace-with-strong-staging-token
CREDENTIAL_ENCRYPTION_KEY=replace-with-long-random-staging-key

# Provider keys used by Test Provider fallback
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Restrict to real frontend origin(s)
CORS_ALLOW_ORIGINS=https://staging.your-frontend-domain.com
